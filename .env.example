# SentencifyAI - Configuração de Ambiente
# Copie este arquivo para .env e preencha suas chaves

# Porta do servidor backend (padrão: 3001)
PORT=3001

# Ambiente (development | production)
NODE_ENV=development

# ========================================
# API Keys (opcional - pode configurar na UI)
# ========================================

# Anthropic (Claude)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# ========================================
# Autenticação Magic Link (v1.34.0)
# ========================================

# Caminho do banco SQLite
# Em produção (Render Starter): /sentencify/sentencify.db
# Em desenvolvimento: ./data/sentencify.db
DB_PATH=./data/sentencify.db

# Chave secreta para JWT (gere com: openssl rand -hex 32)
JWT_SECRET=sua-chave-secreta-muito-longa-e-aleatoria

# Resend API Key (para envio de emails)
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_...

# URL do frontend (para links nos emails)
# Em produção: https://sentencify.onrender.com
# Em desenvolvimento: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ========================================
# Auto-login de DESENVOLVIMENTO (somente local)
# ========================================
# Habilita POST /api/auth/magic/dev-login e o auto-login do frontend, para
# testes (ex.: Playwright) sem precisar passar pelo gate de magic link.
#
# DUPLA TRAVA - nunca ativa em produção:
#   - Backend: exige NODE_ENV!=production E DEV_AUTH_BYPASS=true
#   - Frontend: exige import.meta.env.DEV E VITE_DEV_AUTH_BYPASS=true
#     (import.meta.env.DEV é false no build => bloco é dead-code-eliminated)
#
# Deixe como false/ausente para manter desligado.
DEV_AUTH_BYPASS=false
DEV_USER_EMAIL=dev@localhost
VITE_DEV_AUTH_BYPASS=false
